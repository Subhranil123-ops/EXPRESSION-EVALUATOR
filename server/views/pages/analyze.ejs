<%layout("layouts/boilerplate")%>
<%title="Analyze Code"%>
    <div class="row justify-content-center mt-5">
        <div class="col-md-6">
            <div class="card p-4">
                <form action="/analyze" method="POST">
                    <h2 class="text-center mb-4">Code Analyzer</h2>
                    <div class="mb-3">
                        <label class="form-label">Enter Code</label>
                        <textarea class="form-control" rows="10" name="code"></textarea>
                    </div>
                    <div class="text-center">
                        <button class="btn btn-success">Convert</button>
                    </div>
                </form>
            </div>
        </div>
    </div>