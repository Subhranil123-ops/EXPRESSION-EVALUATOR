<%layout("layouts/boilerplate") %>
<%title="Code Analyzer" %>

<style>
    textarea:focus {
        box-shadow: 0 0 0 0.15rem rgba(13,110,253,.25);
        border-color: #0d6efd;
    }

    .card-hover {
        transition: all 0.2s ease;
    }

    .card-hover:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }
</style>

<div class="row justify-content-center mt-5">
    <div class="col-lg-8">

        <% if(error){ %>
        <div class="alert alert-danger text-center position-relative shadow-sm">
            <button type="button" class="btn-close position-absolute start-0 ms-3" data-bs-dismiss="alert"></button>
            <i class="fa-solid fa-triangle-exclamation me-2"></i>
            <%= error %>
        </div>
        <% } %>

        <!-- FORM -->
        <div class="card shadow-lg border-0 rounded-4 card-hover">
            <div class="card-body p-4">

                <h2 class="text-center mb-3 fw-bold text-primary">
                    Code Analyzer 🧠
                </h2>

                <p class="text-center text-muted mb-4" style="font-size: 0.9rem;">
                    Analyze loops, conditions & estimate time complexity
                </p>

                <form action="/analyze" method="POST">

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Enter Code
                        </label>

                        <textarea 
                            class="form-control font-monospace" 
                            rows="10" 
                            name="code"
                            placeholder="// Paste your code here..."
                            required
                        ></textarea>
                    </div>

                    <div class="d-grid">
                        <button class="btn btn-success fw-semibold py-2">
                            Analyze 🚀
                        </button>
                    </div>

                </form>
            </div>
        </div>

        <!-- OUTPUT -->
        <% if (data) { %>

        <div class="card shadow mt-4 border-0 rounded-4 card-hover">
            <div class="card-body">

                <h4 class="text-center mb-4 text-success fw-bold">
                    Analysis Result
                </h4>

                <div class="row text-center g-3">

                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded h-100">
                            <h6 class="text-muted">For Loops</h6>
                            <h3 class="fw-bold text-primary"><%= data.for %></h3>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded h-100">
                            <h6 class="text-muted">If Conditions</h6>
                            <h3 class="fw-bold text-warning"><%= data.if %></h3>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded h-100">
                            <h6 class="text-muted">Else Blocks</h6>
                            <h3 class="fw-bold text-danger"><%= data.else %></h3>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded h-100">
                            <h6 class="text-muted">While Loops</h6>
                            <h3 class="fw-bold text-info"><%= data.while %></h3>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded h-100">
                            <h6 class="text-muted">Max Depth</h6>
                            <h3 class="fw-bold text-dark"><%= data.maxDepth %></h3>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="p-3 bg-dark text-white rounded h-100">
                            <h6 class="text-light">Time Complexity</h6>
                            <h3 class="fw-bold mb-0"><%= data.estimatedComplexity %></h3>
                        </div>
                    </div>

                </div>

            </div>
        </div>

        <% } %>

    </div>
</div>